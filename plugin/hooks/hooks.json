    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/init-workspace.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
